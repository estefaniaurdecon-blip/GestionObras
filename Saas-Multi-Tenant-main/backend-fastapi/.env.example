# Variables de entorno para el backend FastAPI

ENV=local
DEBUG=true

DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/saas

SECRET_KEY=changeme-super-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# Config multi-tenant (usando subdominios reales en tu dominio)
# Para tenants: acme.mavico.shop, foo.mavico.shop, etc.
PRIMARY_DOMAIN=mavico.shop

# SMTP (opcional, para correos de bienvenida/verificación)
SMTP_HOST=smtp.tu-proveedor.com
SMTP_PORT=587
SMTP_USERNAME=usuario@tu-dominio.com
SMTP_PASSWORD=tu-contraseña
SMTP_FROM=soporte@tu-dominio.com
SMTP_USE_TLS=true


# Moodle Web Services (opcional)
MOODLE_BASE_URL=http://moodle
MOODLE_TOKEN=


# Internal notifications from ERP
SAAS_INTERNAL_API_KEY=changeme-saas-internal-key
