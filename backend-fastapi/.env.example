ENV=local
DEBUG=false

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5433/saas

SECRET_KEY=replace-with-strong-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256
AUTH_COOKIE_NAME=access_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
MFA_TRUST_COOKIE_NAME=mfa_trust_token
MFA_TRUST_HOURS=24

ALLOW_BOOTSTRAP_SUPERADMIN=false
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=replace-with-strong-password

PRIMARY_DOMAIN=empresa.local
FRONTEND_BASE_URL=http://localhost:5173
FRONTEND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_TIMEZONE=Europe/Madrid
CELERY_VISIBILITY_TIMEOUT_SECONDS=3600
CELERY_SOFT_TIME_LIMIT_SECONDS=600
CELERY_TIME_LIMIT_SECONDS=720

OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_HEADERS_JSON=
OLLAMA_OCR_MODEL=deepseek-ocr:3b
OLLAMA_JSON_MODEL=qwen3-coder:30b
OLLAMA_TIMEOUT_SECS=60
OLLAMA_OCR_TIMEOUT_SECONDS=90
OLLAMA_JSON_TIMEOUT_SECONDS=45
AI_HELP_LLM_ENABLED=false
OLLAMA_HELP_MODEL=
OLLAMA_HELP_TIMEOUT_SECONDS=8
AI_CIRCUIT_BREAKER_TTL_SECONDS=60
AI_HEALTH_CHECK_TIMEOUT_SECONDS=5
LOVABLE_API_KEY=

AVATARS_STORAGE_PATH=backend-fastapi/data/avatars
LOGOS_STORAGE_PATH=backend-fastapi/data/logos
PROJECT_DOCS_STORAGE_PATH=backend-fastapi/data/project-docs
WORK_REPORT_IMAGES_STORAGE_PATH=backend-fastapi/data/work-report-images
SHARED_FILES_STORAGE_PATH=backend-fastapi/data/shared-files
DEFAULT_BRAND_ACCENT_COLOR=#00662b

MOODLE_BASE_URL=
MOODLE_TOKEN=
SAAS_INTERNAL_API_KEY=replace-with-internal-api-key

APP_UPDATES_CATALOG_JSON=
APP_UPDATES_DISABLED_VERSIONS=[]
