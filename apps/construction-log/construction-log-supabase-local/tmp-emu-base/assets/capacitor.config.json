{
	"appId": "com.partesdetrabajo.app",
	"appName": "Partes de Trabajo",
	"webDir": "dist",
	"android": {
		"backgroundColor": "#1e3a5f",
		"allowMixedContent": true
	},
	"ios": {
		"contentInset": "automatic"
	},
	"plugins": {
		"SplashScreen": {
			"launchShowDuration": 0,
			"launchAutoHide": false,
			"backgroundColor": "#1e3a5f",
			"showSpinner": false
		}
	},
	"server": {
		"androidScheme": "http",
		"cleartext": true
	}
}
