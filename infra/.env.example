#
# Modo 1: Ollama instalado en el host Windows o en otra maquina accesible.
# Es el modo recomendado para desarrollo con Docker cuando el backend corre
# dentro de contenedores y Ollama corre fuera del stack.
#
OLLAMA_BASE_URL=http://host.docker.internal:11434

#
# Modo 2: Ollama dentro del propio docker compose.
# 1. Cambia OLLAMA_BASE_URL a http://ollama:11434
# 2. Arranca con: docker compose --profile ollama up --build
#
# OLLAMA_BASE_URL=http://ollama:11434

AI_HELP_LLM_ENABLED=false

#
# Modelo recomendado para probar el chat sencillo.
# Si se deja vacio, el backend usara OLLAMA_JSON_MODEL.
#
OLLAMA_HELP_MODEL=qwen2.5:3b
